generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               Int          @id @default(autoincrement())
  name             String
  category         String
  stock            Float
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  pricePerKgCompra Float?
  pricePerKgVenda  Float?
  itensCompra      ItemCompra[]
  itensVenda       ItemVenda[]
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  idade     Int
  email     String
  telefone  String
  cpf       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  compras   Compra[]
  vendas    Venda[]

  @@map("clientes")
}

model Compra {
  id           Int          @id @default(autoincrement())
  fornecedorId Int?
  dataCompra   DateTime     @default(now())
  totalItens   Int          @default(0)
  pesoTotal    Decimal      @default(0.00)
  valorTotal   Decimal      @default(0.00)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  fornecedor   Client?      @relation(fields: [fornecedorId], references: [id])
  itens        ItemCompra[]

  @@map("compras")
}

model ItemCompra {
  id        Int     @id @default(autoincrement())
  compraId  Int
  produtoId Int
  peso      Decimal
  precoKg   Decimal
  subtotal  Decimal @default(0.00)
  compra    Compra  @relation(fields: [compraId], references: [id], onDelete: Cascade)
  produto   Product @relation(fields: [produtoId], references: [id])

  @@map("itens_compra")
}

model Venda {
  id         Int         @id @default(autoincrement())
  clientId   Int?
  dataVenda  DateTime    @default(now())
  totalItens Int         @default(0)
  pesoTotal  Decimal     @default(0.00)
  valorTotal Decimal     @default(0.00)
  itens      ItemVenda[]
  client     Client?     @relation(fields: [clientId], references: [id])

  @@map("vendas")
}

model ItemVenda {
  id        Int     @id @default(autoincrement())
  vendaId   Int
  produtoId Int
  peso      Decimal
  precoKg   Decimal
  subtotal  Decimal @default(0.00)
  produto   Product @relation(fields: [produtoId], references: [id])
  venda     Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  @@map("itens_venda")
}

model Caixa {
  id                  Int       @id @default(autoincrement())
  dataCaixaAbertura   DateTime  @default(now())
  dataCaixaFechamento DateTime?
  lucro               Decimal   @default(0.00)
  despesa             Decimal   @default(0.00)
  receita             Decimal   @default(0.00)
  numTransacoes       Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([dataCaixaFechamento])
  @@map("caixas")
}

